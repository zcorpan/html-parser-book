{
  "name": "html-parser-book",
  "version": "1.2.0",
  "description": "The book 'Idiosyncrasies of the HTML parser'",
  "private": true,
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('_site', { recursive: true, force: true })\"",
    "build": "npm run clean && npm run build:html && npm run build:epub",
    "build:html": "eleventy --config=eleventy.config.mjs --quiet",
    "build:epub": "node tools/build-epub.mjs",
    "serve": "eleventy --config=eleventy.config.mjs --serve --quiet",
    "debug": "DEBUG=* eleventy --config=eleventy.config.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zcorpan/html-parser-book.git"
  },
  "author": "Simon Pieters",
  "license": "CC-BY-4.0",
  "bugs": {
    "url": "https://github.com/zcorpan/html-parser-book/issues"
  },
  "homepage": "https://htmlparser.info/",
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@11ty/eleventy": "3.1.6",
    "markdown-it": "14.2.0",
    "markdown-it-anchor": "9.2.0",
    "markdown-it-deflist": "3.0.0"
  }
}
